---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout title="Blog | Kingsley's AI Portfolio" description="Insights, tutorials, and life updates.">
  <div class="container max-w-4xl mx-auto px-4 py-12">
    <header class="text-center mb-16">
      <h1 class="font-headline text-5xl md:text-6xl font-bold">Blog</h1>
      <p class="mt-4 text-xl text-base-content/60">Thoughts, musings, and tutorials.</p>
    </header>

    <div class="space-y-8">
      {posts.length > 0 ? posts.map((post) => (
        <article class="card bg-base-100 shadow-md border border-base-200">
          <div class="card-body">
            <h2 class="card-title font-headline text-3xl hover:text-primary transition-colors">
              <a href={`/blog/${post.id}/`}>{post.data.title}</a>
            </h2>
            <div class="text-sm text-base-content/60 mt-2 mb-4">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('en-GB', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
            </div>
            <p class="text-base-content/80 text-lg leading-relaxed">{post.data.description}</p>
            <div class="card-actions justify-end mt-4">
              <a href={`/blog/${post.id}/`} class="btn btn-primary btn-sm">Read full post</a>
            </div>
          </div>
        </article>
      )) : (
        <p class="text-center text-base-content/60">No posts found.</p>
      )}
    </div>
  </div>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import { portfolioData } from "../data/portfolio";
import { Icon } from "astro-icon/components";

const {
  profile,
  contact,
  skills,
  workExperience,
  projects,
  education,
  awards,
  volunteering,
  interests,
} = portfolioData;
---

<Layout
  title="About | Kingsley's AI Portfolio"
  description="Learn more about Kingsley, the AI & Full-Stack Developer."
>
  <div class="container max-w-5xl mx-auto px-4 py-8">
    <!-- Hero Section -->
    <header
      class="flex flex-col md:flex-row items-center gap-8 md:gap-12 py-16 text-center md:text-left"
    >
      <div class="avatar">
        <div
          class="w-32 h-32 md:w-40 md:h-40 rounded-full ring ring-primary ring-offset-base-100 ring-offset-2 overflow-hidden shadow-lg object-cover"
        >
          <img
            src={profile.avatar}
            alt={profile.name}
            data-ai-hint="man portrait"
          />
        </div>
      </div>
      <div>
        <h1 class="font-headline text-5xl md:text-6xl font-bold">
          {profile.name}
        </h1>
        <p class="mt-2 text-sm text-base-content/60">
          Preferred name: Kingsley Leung (He/Him)
        </p>
        <p
          class="mt-2 text-xl md:text-2xl text-primary font-semibold leading-relaxed"
        >
          <span class="whitespace-nowrap">Software Developer</span> |
          <span class="whitespace-nowrap">C#, Python & TypeScript</span> |
          <span class="whitespace-nowrap"
            >Passionate about AI-Driven Problem-Solving and DevOps</span
          >
        </p>
        <p class="mt-4 text-lg text-base-content/80">{profile.summary}</p>
        <div
          class="mt-6 flex flex-col sm:flex-row gap-4 justify-center md:justify-start"
        >
          <a
            href={profile.resumeUrl}
            download="Kingsley_Leung_Resume.pdf"
            class="btn btn-primary btn-lg"
          >
            <Icon name="ph:download-simple" class="mr-2 h-4 w-4" />
            Download CV
          </a>
          <a
            href={profile.transcriptUrl}
            download="Kingsley_Leung_Academic_Transcript.pdf"
            class="btn btn-outline btn-lg"
          >
            <Icon name="ph:download-simple" class="mr-2 h-4 w-4" />
            Download Transcript
          </a>
        </div>
      </div>
    </header>

    <div class="divider"></div>

    <!-- Contact Section -->
    <section class="py-12 md:py-16">
      <div class="flex items-center gap-3 mb-8">
        <Icon name="ph:envelope" class="w-8 h-8 text-primary" />
        <h2 class="text-3xl font-headline text-primary">Contact Me</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-lg">
        <div class="flex items-center gap-3">
          <Icon name="ph:envelope" class="w-5 h-5 text-base-content/60" />
          <a
            href={`mailto:${contact.email}`}
            class="hover:text-primary transition-colors"
            >{contact.email}
          </a>
        </div>
        <div class="flex items-center gap-3">
          <Icon name="ph:phone" class="w-5 h-5 text-base-content/60" />
          <span>{contact.phone}</span>
        </div>
        <div class="flex items-center gap-3">
          <Icon name="ph:map-pin" class="w-5 h-5 text-base-content/60" />
          <span>{contact.location}</span>
        </div>
        <div class="flex items-center gap-3">
          <div class="flex items-center gap-3">
            <Icon name="ph:linkedin-logo" class="w-5 h-5 text-base-content/60" />
            <a
              href={contact.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-primary transition-colors"
              >LinkedIn
            </a>
          </div>
          <div class="flex items-center gap-3 ml-4">
            <Icon name="ph:github-logo" class="w-5 h-5 text-base-content/60" />
            <a
              href={contact.github}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-primary transition-colors"
              >GitHub
            </a>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- Skills Section -->
    <section class="py-12 md:py-16">
      <div class="flex items-center gap-3 mb-8">
        <Icon name="ph:user" class="w-8 h-8 text-primary" />
        <h2 class="text-3xl font-headline text-primary">Skills</h2>
      </div>
      <div class="flex flex-wrap gap-2">
        {
          skills.map((skill) => (
            <div class="badge badge-secondary badge-lg py-3 px-4 shadow-sm">
              {skill}
            </div>
          ))
        }
      </div>
    </section>

    <div class="divider"></div>

    <!-- Work Experience -->
    <section class="py-12 md:py-16">
      <div class="flex items-center gap-3 mb-8">
        <Icon name="ph:briefcase" class="w-8 h-8 text-primary" />
        <h2 class="text-3xl font-headline text-primary">Work Experience</h2>
      </div>
      <div class="space-y-8 border-l-2 border-primary/30 pl-8 ml-4 relative">
        {
          workExperience.map((job) => (
            <div class="card bg-base-100 shadow-sm border border-base-200 relative">
              <span class="absolute -left-10 md:-left-12 top-6 w-4 h-4 rounded-full bg-primary ring-4 ring-base-100" />
              <div class="card-body">
                <h3 class="card-title font-headline text-2xl">{job.role}</h3>
                <p class="text-base-content/60 mb-2">
                  {job.company} | {job.period}
                </p>
                <ul class="list-disc pl-5 space-y-1 text-base-content/80 mb-4">
                  {job.description.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
                <div class="flex flex-wrap gap-2 mt-2">
                  {job.tags.map((tag) => (
                    <span class="badge badge-outline">{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <div class="divider"></div>

    <!-- Projects Experience -->
    <section class="py-12 md:py-16">
      <div class="flex items-center gap-3 mb-8">
        <Icon name="ph:book-open" class="w-8 h-8 text-primary" />
        <h2 class="text-3xl font-headline text-primary">Projects</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {
          projects.map((project) => (
            <div class="card bg-base-100 shadow-sm border border-base-200">
              <div class="card-body flex flex-col h-full">
                <h3 class="card-title font-headline text-2xl mb-2">
                  {project.name}
                </h3>
                <ul class="list-disc pl-5 space-y-1 text-base-content/80 flex-1">
                  {Array.isArray(project.description) ? (
                    project.description.map((item) => <li>{item}</li>)
                  ) : (
                    <li>{project.description}</li>
                  )}
                </ul>
                <div class="flex flex-wrap gap-2 my-4">
                  {project.tags.map((tag) => (
                    <span class="badge badge-outline badge-md">{tag}</span>
                  ))}
                </div>
                <div class="card-actions justify-end mt-auto">
                  <a
                    href={project.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn btn-outline btn-sm"
                  >
                    View Project{" "}
                    <Icon name="ph:arrow-square-out" class="ml-2 h-4 w-4" />
                  </a>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <div class="divider"></div>

    <!-- Education -->
    <section class="py-12 md:py-16">
      <div class="flex items-center gap-3 mb-8">
        <Icon name="ph:graduation-cap" class="w-8 h-8 text-primary" />
        <h2 class="text-3xl font-headline text-primary">Education</h2>
      </div>
      <div class="space-y-8 border-l-2 border-primary/30 pl-8 ml-4 relative">
        {
          education.map((edu) => (
            <div class="card bg-base-100 shadow-sm border border-base-200 relative">
              <span class="absolute -left-10 md:-left-12 top-6 w-4 h-4 rounded-full bg-primary ring-4 ring-base-100" />
              <div class="card-body">
                <h3 class="card-title font-headline text-xl">{edu.degree}</h3>
                <p class="text-base-content/60 mb-2">
                  {edu.institution} | {edu.period}
                </p>
                <ul class="list-disc pl-5 space-y-1 text-base-content/80 mb-4">
                  {edu.description.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
                <div class="flex flex-wrap gap-2 mt-2">
                  {edu.tags.map((tag) => (
                    <span class="badge badge-outline">{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <div class="divider"></div>

    <!-- Awards -->
    <section class="py-12 md:py-16">
      <div class="flex items-center gap-3 mb-8">
        <Icon name="ph:medal" class="w-8 h-8 text-primary" />
        <h2 class="text-3xl font-headline text-primary">
          Awards & Certifications
        </h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {
          awards.map((award) => (
            <div class="card bg-base-100 shadow-sm border border-base-200">
              <div class="card-body">
                <h3 class="card-title font-headline text-xl">{award.name}</h3>
                <p class="text-base-content/60 mb-2">{award.issuer}</p>
                <ul class="list-disc pl-5 space-y-1 text-base-content/80 mb-4">
                  {Array.isArray(award.description) ? (
                    award.description.map((item) => <li>{item}</li>)
                  ) : (
                    <li>{award.description}</li>
                  )}
                </ul>
                <div class="flex flex-wrap gap-2 mt-4">
                  {award.tags.map((tag) => (
                    <span class="badge badge-outline">{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <div class="divider"></div>

    <div class="grid md:grid-cols-2 gap-12">
      <!-- Volunteering -->
      <section class="py-12 md:py-16">
        <div class="flex items-center gap-3 mb-8">
          <Icon name="ph:heart" class="w-8 h-8 text-primary" />
          <h2 class="text-3xl font-headline text-primary">Volunteering</h2>
        </div>
        <div class="space-y-6">
          {
            volunteering.map((item) => (
              <div>
                <h3 class="text-xl font-bold">
                  {item.role} at {item.organization}
                </h3>
                <p class="text-sm text-base-content/60 mb-2">{item.period}</p>
                <ul class="list-disc pl-5 space-y-1 text-base-content/80">
                  {item.description.map((desc) => (
                    <li>{desc}</li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </section>

      <!-- Interests -->
      <section class="py-12 md:py-16">
        <div class="flex items-center gap-3 mb-8">
          <Icon name="ph:heart" class="w-8 h-8 text-primary" />
          <h2 class="text-3xl font-headline text-primary">Interests</h2>
        </div>
        <ul
          class="space-y-3 list-disc list-inside text-base-content/80 text-lg"
        >
          {interests.map((interest) => <li>{interest}</li>)}
        </ul>
      </section>
    </div>
  </div>
</Layout>

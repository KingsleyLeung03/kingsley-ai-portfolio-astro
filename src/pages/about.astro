---
import Layout from '../layouts/Layout.astro';
import { portfolioData } from '../data/portfolio';

const {
  profile,
  contact,
  skills,
  workExperience,
  projects,
  education,
  awards,
  volunteering,
  interests,
} = portfolioData;

// SVG Icons
const MailIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`;
const PhoneIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`;
const MapPinIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`;
const UserIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`;
const BriefcaseIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>`;
const BookOpenIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`;
const GraduationCapIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>`;
const AwardIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>`;
const HeartIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>`;
const ExternalLinkIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2 h-4 w-4"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>`;
const DownloadIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 h-4 w-4"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>`;
const LinkedinIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 h-4 w-4"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>`;
const GithubIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 h-4 w-4"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>`;
---

<Layout title="About | Kingsley's AI Portfolio" description="Learn more about Kingsley, the AI & Full-Stack Developer.">
  <div class="container max-w-5xl mx-auto px-4 py-8">
    <!-- Hero Section -->
    <header class="flex flex-col md:flex-row items-center gap-8 md:gap-12 py-16 text-center md:text-left">
      <div class="avatar">
        <div class="w-32 h-32 md:w-40 md:h-40 rounded-full ring ring-primary ring-offset-base-100 ring-offset-2 overflow-hidden shadow-lg object-cover">
          <img src={profile.avatar} alt={profile.name} data-ai-hint="man portrait" />
        </div>
      </div>
      <div>
        <h1 class="font-headline text-5xl md:text-6xl font-bold">{profile.name}</h1>
        <p class="mt-2 text-sm text-base-content/60">Preferred name: Kingsley Leung (He/Him)</p>
        <p class="mt-2 text-xl md:text-2xl text-primary font-semibold leading-relaxed">
          <span class="whitespace-nowrap">Software Developer</span> | 
          <span class="whitespace-nowrap">C#, Python & TypeScript</span> | 
          <span class="whitespace-nowrap">Passionate about AI-Driven Problem-Solving and DevOps</span>
        </p>
        <p class="mt-4 text-lg text-base-content/80">{profile.summary}</p>
        <div class="mt-6 flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
          <a href={profile.resumeUrl} download="Kingsley_Leung_Resume.pdf" class="btn btn-primary btn-lg">
            <Fragment set:html={DownloadIcon} />
            Download CV
          </a>
          <a href={profile.transcriptUrl} download="Kingsley_Leung_Academic_Transcript.pdf" class="btn btn-outline btn-lg">
            <Fragment set:html={DownloadIcon} />
            Download Transcript
          </a>
        </div>
      </div>
    </header>

    <div class="divider"></div>

    <!-- Contact Section -->
    <section class="py-12 md:py-16">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-8 h-8 text-primary" set:html={MailIcon}></div>
        <h2 class="text-3xl font-headline text-primary">Contact Me</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-lg">
        <div class="flex items-center gap-3">
          <div class="w-5 h-5 text-base-content/60" set:html={MailIcon}></div>
          <a href={`mailto:${contact.email}`} class="hover:text-primary transition-colors">{contact.email}</a>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-5 h-5 text-base-content/60" set:html={PhoneIcon}></div>
          <span>{contact.phone}</span>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-5 h-5 text-base-content/60" set:html={MapPinIcon}></div>
          <span>{contact.location}</span>
        </div>
        <div class="flex items-center gap-3">
          <a href={contact.linkedin} target="_blank" rel="noopener noreferrer" class="btn btn-ghost btn-sm">
            <Fragment set:html={LinkedinIcon} /> LinkedIn
          </a>
          <a href={contact.github} target="_blank" rel="noopener noreferrer" class="btn btn-ghost btn-sm">
            <Fragment set:html={GithubIcon} /> GitHub
          </a>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- Skills Section -->
    <section class="py-12 md:py-16">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-8 h-8 text-primary" set:html={UserIcon}></div>
        <h2 class="text-3xl font-headline text-primary">Skills</h2>
      </div>
      <div class="flex flex-wrap gap-2">
        {skills.map((skill) => (
          <div class="badge badge-secondary badge-lg py-3 px-4 shadow-sm">{skill}</div>
        ))}
      </div>
    </section>

    <div class="divider"></div>

    <!-- Work Experience -->
    <section class="py-12 md:py-16">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-8 h-8 text-primary" set:html={BriefcaseIcon}></div>
        <h2 class="text-3xl font-headline text-primary">Work Experience</h2>
      </div>
      <div class="space-y-8 border-l-2 border-primary/30 pl-8 ml-4 relative">
        {workExperience.map((job) => (
          <div class="card bg-base-100 shadow-sm border border-base-200 relative">
            <span class="absolute -left-10 md:-left-12 top-6 w-4 h-4 rounded-full bg-primary ring-4 ring-base-100"></span>
            <div class="card-body">
              <h3 class="card-title font-headline text-2xl">{job.role}</h3>
              <p class="text-base-content/60 mb-2">{job.company} | {job.period}</p>
              <ul class="list-disc pl-5 space-y-1 text-base-content/80 mb-4">
                {job.description.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
              <div class="flex flex-wrap gap-2 mt-2">
                {job.tags.map((tag) => (
                  <span class="badge badge-outline">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <div class="divider"></div>

    <!-- Projects Experience -->
    <section class="py-12 md:py-16">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-8 h-8 text-primary" set:html={BookOpenIcon}></div>
        <h2 class="text-3xl font-headline text-primary">Projects</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {projects.map((project) => (
          <div class="card bg-base-100 shadow-sm border border-base-200">
            <div class="card-body flex flex-col h-full">
              <h3 class="card-title font-headline text-2xl mb-2">{project.name}</h3>
              <ul class="list-disc pl-5 space-y-1 text-base-content/80 flex-1">
                {Array.isArray(project.description) ? project.description.map((item) => (
                  <li>{item}</li>
                )) : <li>{project.description}</li>}
              </ul>
              <div class="flex flex-wrap gap-2 my-4">
                {project.tags.map((tag) => (
                  <span class="badge badge-outline badge-md">{tag}</span>
                ))}
              </div>
              <div class="card-actions justify-end mt-auto">
                <a href={project.link} target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-sm">
                  View Project <Fragment set:html={ExternalLinkIcon} />
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <div class="divider"></div>

    <!-- Education -->
    <section class="py-12 md:py-16">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-8 h-8 text-primary" set:html={GraduationCapIcon}></div>
        <h2 class="text-3xl font-headline text-primary">Education</h2>
      </div>
      <div class="space-y-8 border-l-2 border-primary/30 pl-8 ml-4 relative">
        {education.map((edu) => (
          <div class="card bg-base-100 shadow-sm border border-base-200 relative">
            <span class="absolute -left-10 md:-left-12 top-6 w-4 h-4 rounded-full bg-primary ring-4 ring-base-100"></span>
            <div class="card-body">
              <h3 class="card-title font-headline text-xl">{edu.degree}</h3>
              <p class="text-base-content/60 mb-2">{edu.institution} | {edu.period}</p>
              <ul class="list-disc pl-5 space-y-1 text-base-content/80 mb-4">
                {edu.description.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
              <div class="flex flex-wrap gap-2 mt-2">
                {edu.tags.map((tag) => (
                  <span class="badge badge-outline">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <div class="divider"></div>

    <!-- Awards -->
    <section class="py-12 md:py-16">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-8 h-8 text-primary" set:html={AwardIcon}></div>
        <h2 class="text-3xl font-headline text-primary">Awards & Certifications</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {awards.map((award) => (
          <div class="card bg-base-100 shadow-sm border border-base-200">
            <div class="card-body">
              <h3 class="card-title font-headline text-xl">{award.name}</h3>
              <p class="text-base-content/60 mb-2">{award.issuer}</p>
              <ul class="list-disc pl-5 space-y-1 text-base-content/80 mb-4">
                {Array.isArray(award.description) ? award.description.map((item) => (
                  <li>{item}</li>
                )) : <li>{award.description}</li>}
              </ul>
              <div class="flex flex-wrap gap-2 mt-4">
                {award.tags.map((tag) => (
                  <span class="badge badge-outline">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <div class="divider"></div>

    <div class="grid md:grid-cols-2 gap-12">
      <!-- Volunteering -->
      <section class="py-12 md:py-16">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-8 h-8 text-primary" set:html={HeartIcon}></div>
          <h2 class="text-3xl font-headline text-primary">Volunteering</h2>
        </div>
        <div class="space-y-6">
          {volunteering.map((item) => (
            <div>
              <h3 class="text-xl font-bold">{item.role} at {item.organization}</h3>
              <p class="text-sm text-base-content/60 mb-2">{item.period}</p>
              <ul class="list-disc pl-5 space-y-1 text-base-content/80">
                {item.description.map((desc) => (
                  <li>{desc}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <!-- Interests -->
      <section class="py-12 md:py-16">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-8 h-8 text-primary" set:html={HeartIcon}></div>
          <h2 class="text-3xl font-headline text-primary">Interests</h2>
        </div>
        <ul class="space-y-3 list-disc list-inside text-base-content/80 text-lg">
          {interests.map((interest) => (
            <li>{interest}</li>
          ))}
        </ul>
      </section>
    </div>
  </div>
</Layout>

---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { NAV_ITEMS } from "../consts";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Kingsley's AI Portfolio",
  description = "A personal portfolio for Kingsley, powered by AI.",
} = Astro.props;

const pathname = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead title={title} description={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=PT+Sans:ital,wght@0,400;0,700;1,400;1,700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --font-body: "PT Sans", sans-serif;
        --font-headline: "Playfair Display", serif;
      }
      .font-body {
        font-family: var(--font-body);
      }
      .font-headline {
        font-family: var(--font-headline);
      }
    </style>
  </head>
  <body class="font-body antialiased bg-base-200 text-base-content min-h-screen">
    <div class="drawer drawer-end">
      <input id="main-drawer" type="checkbox" class="drawer-toggle" />
      <div class="drawer-content flex flex-col min-h-screen">
        <Header />
        <main class="flex-1 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
          <slot />
        </main>
        <Footer />
      </div>
      <div class="drawer-side z-50">
        <label for="main-drawer" aria-label="close sidebar" class="drawer-overlay"
        ></label>
        <ul class="menu bg-base-200 min-h-full w-80 p-4 pt-20">
          {
            NAV_ITEMS.map((item) => (
              <li>
                <a
                  href={item.href}
                  class={pathname === item.href ? "active font-bold" : ""}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </body>
</html>
